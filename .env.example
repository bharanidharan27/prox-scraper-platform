# Proxy configuration (e.g. Brightdata, Oxylabs, Smartproxy)
PROXY_URL=http://proxy.provider.com:8080
PROXY_USERNAME=your_proxy_username
PROXY_PASSWORD=your_proxy_password

# Redis URL (for production cache — SQLite used in local/dev mode)
REDIS_URL=redis://localhost:6379

# Secret management (prod: use AWS Secrets Manager / GCP Secret Manager)
# Locally, copy this file to .env and fill in values
APP_ENV=development

# Scraper concurrency limits per retailer
CONCURRENCY_KROGER=3
CONCURRENCY_WALMART=3
CONCURRENCY_DEFAULT=2

# Circuit breaker config
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT_MS=60000

# Rate limiting (requests per minute per retailer)
RATE_LIMIT_KROGER=30
RATE_LIMIT_WALMART=30
RATE_LIMIT_DEFAULT=20

# TTL cache (seconds)
CACHE_TTL_SECONDS=3600

# Spend guardrail: max proxy requests per hour
SPEND_GUARDRAIL_MAX_REQUESTS_PER_HOUR=500
